# =========================================================================
# TEMPLATE KONFIGURASI ENVIRONMENT (Pick Your Photo)
# =========================================================================
# Salin berkas ini ke `.env.local` lalu isi nilainya sebelum menjalankan aplikasi.
# JANGAN PERNAH melakukan commit pada file `.env.local` asli ke repositori Git.

# 🔑 JWT Authentication Secret
# Digunakan untuk menandatangani token sesi login admin & vendor.
# Rekomendasi: Gunakan string acak panjang yang aman (misal hasil dari `openssl rand -hex 32`).
JWT_SECRET=isi_dengan_string_acak_panjang_dan_aman

# 👑 Kredensial Default Superadmin (SaaS Owner)
# Akun ini otomatis dibuat saat database pertama kali diinisialisasi.
ADMIN_EMAIL=amsdev@gmail.com
ADMIN_PASSWORD=amsdev123

# 📁 Google Drive API Key (Penting untuk Importer)
# Dapatkan dari Google Cloud Console dengan hak akses untuk membaca file/folder publik.
GOOGLE_API_KEY=ganti_dengan_api_key_gdrive_anda

# 💽 Jalur Penyimpanan Volume Disk (Docker / External Mount)
# Biarkan default jika memakai disk standar OS VPS, atau ganti jika memakai disk external (/mnt/...)
DB_PATH=./data
STAGING_PATH=./public/staging_uploads
LOGOS_PATH=./public/vendor_logos

